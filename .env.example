# Resend API Key for email sending
# Get your API key from: https://resend.com/api-keys
# Sign up at: https://resend.com/signup
RESEND_API_KEY=re_your_api_key_here

# Email configuration
# The "from" email address - must be verified in Resend dashboard
RESEND_FROM_EMAIL=Heaven Management <noreply@heaven-management.com>

# The destination email address
RESEND_TO_EMAIL=contact@heaven-management.com
